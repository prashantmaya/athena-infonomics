        {
          "name": "POST Create Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.id) {",
                  "    pm.collectionVariables.set('case_id', String(json.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"programId\": {{program_id}},\n  \"caseType\": \"{{case_type_slug}}\",\n  \"title\": \"Postman Demo Case\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/cases/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cases",
                ""
              ]
            }
          },
          "response": []
